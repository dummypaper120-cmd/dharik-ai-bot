name: 24/7 Dharik AI Engine
on:
  schedule:
    - cron: '*/2 * * * *' # Ovvoru 2 nimishathukkum automatic-aa run aagum
  workflow_dispatch:

jobs:
  run-bot:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Use Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'
      - name: Run Engine
        run: node bot.js
